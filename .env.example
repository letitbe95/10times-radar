# 飞书自定义机器人 Webhook（群设置 → 机器人 → 自定义机器人）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# 自定义 OpenAI 兼容 API（推荐）
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL=your-model-name

# 或使用 LiteLLM provider 格式（设置后优先于 LLM_MODEL）
# LLM_PROVIDER=openai/gpt-4o-mini
# OPENAI_API_KEY=sk-...

# 可选
LISTING_URL=https://10times.com/zh-CN/power-energy/tradeshows
# 0 = 抓取全部分页（约 500 页 / 5000 场）；可设正整数限制页数
MAX_PAGES=0
STATE_PATH=data/seen_events.json
PAGE_TIMEOUT_MS=90000
# DRY_RUN=1
# crawl4ai | browser-use | auto（默认 auto，Cloudflare 失败时回退 browser-use）
CRAWLER_BACKEND=auto
# macOS 建议 false（headed 才能过 Cloudflare）；CI 用 xvfb + headed
BROWSER_HEADLESS=false
CF_WAIT_SECONDS=18

# --- GitHub Actions / CI 登录态（二选一，推荐 Cloud Profile）---
# Browser Use Cloud API Key（必填）
# BROWSER_USE_API_KEY=bu_...
# 本地运行 `python3 scripts/sync_cloud_profile.py` 后得到的 Profile ID
# BROWSER_USE_CLOUD_PROFILE_ID=66f82d67-61d0-497e-ae08-4642f3746752
# 备选：Cookie JSON 的 base64（`python3 scripts/export_10times_cookies.py` 生成）
# TENTIMES_COOKIES_B64=
# 或本地 Cookie 文件路径
# TENTIMES_COOKIES_PATH=data/10times_cookies.json
